chunk on

###############################################################################
# KG-grounded light-processing agent with annotation-provided goals
#
# Expected goal input on input-link:
#
#   ^event-id <e>
#   ^goal <g>
#   <g> ^z1 <value1>
#       ^z2 <value2>
#       ^url <target-profile-url>
#
# Required RHS functions:
# - discretize-light-level <numeric>
# - kg-value <kg-url> <local-property-name>
# - kg-action-field <kg-url> <device> <activate> <field>
# - wait <milliseconds>
#
# Main control-flow design:
# 1. Initialize URLs.
# 2. Register profile and query annotations.
# 3. Wait for an annotation-provided goal on the input-link.
# 4. Copy the goal into persistent Soar state.
# 5. Load the action model from the KG.
# 6. Refresh raw percepts from the KG.
# 7. Discretize z1/z2 light levels through a selected operator.
# 8. Select and execute applicable KG actions.
# 9. Refresh after every action.
# 10. Confirm the pending action once its postcondition appears.
# 11. Refresh again after confirmation before planning the next action.
# 12. Complete the goal once the discretized state matches the goal.
#
# Important fixes:
# - No self-negating elaboration rules for z1d/z2d.
# - Action tie-breaking is done at the top state.
# - After confirm-pending, ^needs-refresh true is set again, so the agent does
#   not continue planning from a possibly stale percept object.
# - Candidate action proposals are disabled while ^needs-refresh true exists.
# - Refresh removes stale percept readiness flags.
###############################################################################

###############################################################################
# Initialization
###############################################################################

sp {light-processing*propose*initialize
   (state <s> ^superstate nil
              -^light-processing-initialized true)
-->
   (print-action |[light-processing] PROPOSE initialize|)
   (<o> ^name initialize-light-processing)
   (<s> ^operator <o> + =)
}

sp {light-processing*apply*initialize
   (state <s> ^superstate nil
              ^operator <o>)
   (<o> ^name initialize-light-processing)
-->
   (print-action |[light-processing] APPLY initialize|)
   (<s> ^light-processing-initialized true
        ^profile-url |http://localhost:8083/profile|
        ^td-url |http://localhost:5001/td|
        ^kg-url |http://localhost:8081/kg|
        ^headers |{}|
        ^max-iterations 100)
}

###############################################################################
# Register profile once at startup
###############################################################################

sp {light-processing*propose*start
   (state <s> ^superstate nil
              ^light-processing-initialized true
              ^profile-url <profile-url>
              ^td-url <td-url>
              -^started true)
-->
   (print-action |[light-processing] PROPOSE start: register profile|)
   (<o> ^name start-light-processing)
   (<s> ^operator <o> + =)
}

sp {light-processing*apply*start
   (state <s> ^superstate nil
              ^operator <o>
              ^profile-url <profile-url>
              ^td-url <td-url>
              ^io.output-link <ol>)
   (<o> ^name start-light-processing)
-->
   (print-action |[light-processing] APPLY start: register profile|)

   (<cmd1> ^td-url <td-url>
           ^profile-url <profile-url>)
   (<ol> ^register-profile <cmd1>)

   (<s> ^started true)
}

###############################################################################
# Waiting for a goal annotation
###############################################################################

sp {light-processing*propose*wait-for-goal-a
   (state <s> ^superstate nil
              ^started true
              -^active-goal <ag>
              ^profile-url <profile-url>
              ^td-url <td-url>
              ^io.input-link <il>)
   -(<s> ^wait-toggle b)
-->
   (print-action |[light-processing] PROPOSE wait-for-goal A|)
   (<o> ^name wait-for-goal
        ^next-toggle b)
   (<s> ^operator <o> + =)
}

sp {light-processing*propose*wait-for-goal-b
   (state <s> ^superstate nil
              ^started true
              ^wait-toggle b
              -^active-goal <ag>
              ^profile-url <profile-url>
              ^td-url <td-url>
              ^io.input-link <il>)
-->
   (print-action |[light-processing] PROPOSE wait-for-goal B|)
   (<o> ^name wait-for-goal
        ^next-toggle a)
   (<s> ^operator <o> + =)
}

sp {light-processing*apply*wait-for-goal-a
   (state <s> ^superstate nil
              ^operator <o>)
   (<o> ^name wait-for-goal
        ^next-toggle a)
-->
   (print-action |[light-processing] APPLY wait-for-goal A: waiting for automatically perceived annotation|)

   (wait 5000)

   (<s> ^wait-toggle a)
   (<s> ^wait-toggle b -)
}

sp {light-processing*apply*wait-for-goal-b
   (state <s> ^superstate nil
              ^operator <o>)
   (<o> ^name wait-for-goal
        ^next-toggle b)
-->
   (print-action |[light-processing] APPLY wait-for-goal B: waiting for automatically perceived annotation|)

   (wait 5000)

   (<s> ^wait-toggle b)
   (<s> ^wait-toggle a -)
}

###############################################################################
# Begin a new goal event from annotation-provided input-link WMEs
###############################################################################

sp {light-processing*propose*begin-goal-event
   (state <s> ^superstate nil
              ^started true
              -^active-goal <ag>
              ^io.input-link <il>)
   (<il> ^event-id <e>
         ^goal <input-goal>)
   (<input-goal> ^z1 <goal-z1>
                 ^z2 <goal-z2>
                 ^url <goal-url>)
   -(<s> ^processed-event <e>)
-->
   (print-action |[light-processing] PROPOSE begin-goal-event: z1=| <goal-z1> | z2=| <goal-z2> | url=| <goal-url>)
   (<o> ^name begin-goal-event
        ^event-id <e>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*begin-goal-event-over-wait
   (state <s> ^superstate nil
              ^operator <begin> +
              ^operator <wait> +)
   (<begin> ^name begin-goal-event)
   (<wait> ^name wait-for-goal)
-->
   (print-action |[light-processing] PREFERENCE: begin-goal-event over wait-for-goal|)
   (<s> ^operator <begin> > <wait>)
}

sp {light-processing*reset-action-model-loaded-on-begin
   (state <s> ^superstate nil
              ^operator <o>
              ^action-model-loaded true)
   (<o> ^name begin-goal-event)
-->
   (print-action |[light-processing] RESET action-model-loaded for new goal|)
   (<s> ^action-model-loaded true -)
}

sp {light-processing*remove-old-iteration-on-begin
   (state <s> ^superstate nil
              ^operator <o>
              ^iteration <old-iteration>)
   (<o> ^name begin-goal-event)
-->
   (print-action |[light-processing] REMOVE old iteration counter before new goal|)
   (<s> ^iteration <old-iteration> -)
}

sp {light-processing*apply*begin-goal-event
   (state <s> ^superstate nil
              ^operator <o>)
   (<o> ^name begin-goal-event
        ^event-id <e>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>)
-->
   (print-action |[light-processing] APPLY begin-goal-event: copied goal into Soar state and reset iteration counter|)

   (<ag> ^event-id <e>
         ^z1 <goal-z1>
         ^z2 <goal-z2>
         ^url <goal-url>)

   (<s> ^active-goal <ag>
        ^goal-event <e>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>
        ^processed-event <e>
        ^iteration 0
        ^needs-refresh true)

   (<s> ^wait-toggle a -)
   (<s> ^wait-toggle b -)
}

###############################################################################
# Failure handling
###############################################################################

sp {light-processing*propose*fail-goal-max-iterations
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^goal-event <event-id>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^goal-url <goal-url>
              ^max-iterations <max>
              ^iteration { <iteration> >= <max> })
-->
   (print-action |[light-processing] PROPOSE fail-goal: max iterations reached. iteration=| <iteration> | max=| <max>)
   (<o> ^name fail-goal
        ^reason max-iterations
        ^event-id <event-id>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>
        ^iteration <iteration>
        ^max-iterations <max>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*complete-goal-over-fail-goal
   (state <s> ^superstate nil
              ^operator <complete> +
              ^operator <fail> +)
   (<complete> ^name complete-goal)
   (<fail> ^name fail-goal)
-->
   (print-action |[light-processing] PREFERENCE: complete-goal over fail-goal|)
   (<s> ^operator <complete> > <fail>)
}

sp {light-processing*prefer*fail-goal-over-refresh
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name refresh-kg)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over refresh-kg|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-load-action-model
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name load-action-model)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over load-action-model|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-discretize
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name discretize-percepts)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over discretize-percepts|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-action
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name perform-kg-action)
-->
   (print-action |[light-processing] PREFERENCE: KG action over fail-goal|)
   (<s> ^operator <other> > <fail>)
}

sp {light-processing*prefer*fail-goal-over-confirm
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name confirm-pending)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over confirm-pending|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-wait-feedback
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name wait-for-feedback)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over wait-for-feedback|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*apply*fail-goal
   (state <s> ^superstate nil
              ^operator <o>
              ^active-goal <ag>
              ^goal-event <event-id>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^goal-url <goal-url>
              ^td-url <td-url>
              ^io.output-link <ol>)
   (<o> ^name fail-goal
        ^reason <reason>)
-->
   (print-action |[light-processing] APPLY fail-goal: reason=| <reason> |; sending direct done=false annotation to | <goal-url>)

   (<cmd-done> ^done false
               ^reason <reason>
               ^event-id <event-id>
               ^goal-z1 <goal-z1>
               ^goal-z2 <goal-z2>
               ^url <goal-url>
               ^td-url <td-url>)
   (<ol> ^send-message <cmd-done>)

   (<s> ^active-goal <ag> -
        ^goal-event <event-id> -
        ^goal-z1 <goal-z1> -
        ^goal-z2 <goal-z2> -
        ^goal-url <goal-url> -)

   (print-action |[light-processing] APPLY fail-goal: failed event=| <event-id> | reason=| <reason> |; waiting for next goal|)
}

sp {light-processing*cleanup-percepts-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <p>)
   (<o> ^name fail-goal)
-->
   (<s> ^percepts <p> -)
}

sp {light-processing*cleanup-percepts-ready-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts-ready true)
   (<o> ^name fail-goal)
-->
   (<s> ^percepts-ready true -)
}

sp {light-processing*cleanup-raw-percepts-ready-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^raw-percepts-ready true)
   (<o> ^name fail-goal)
-->
   (<s> ^raw-percepts-ready true -)
}

sp {light-processing*cleanup-needs-refresh-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^needs-refresh true)
   (<o> ^name fail-goal)
-->
   (<s> ^needs-refresh true -)
}

sp {light-processing*cleanup-pending-device-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^pending-device <device>)
   (<o> ^name fail-goal)
-->
   (<s> ^pending-device <device> -)
}

sp {light-processing*cleanup-pending-activate-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^pending-activate <activate>)
   (<o> ^name fail-goal)
-->
   (<s> ^pending-activate <activate> -)
}

sp {light-processing*cleanup-pending-post-attribute-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^pending-post-attribute <post-attribute>)
   (<o> ^name fail-goal)
-->
   (<s> ^pending-post-attribute <post-attribute> -)
}

sp {light-processing*cleanup-pending-post-value-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^pending-post-value <post-value>)
   (<o> ^name fail-goal)
-->
   (<s> ^pending-post-value <post-value> -)
}

sp {light-processing*cleanup-iteration-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^iteration <iteration>)
   (<o> ^name fail-goal)
-->
   (<s> ^iteration <iteration> -)
}

###############################################################################
# Load the action model from the KG
###############################################################################

sp {light-processing*propose*load-action-model
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^kg-url <kg-url>
              ^iteration { <iteration> < <max> }
              ^max-iterations <max>
              -^action-model-loaded true)
-->
   (print-action |[light-processing] PROPOSE load-action-model|)
   (<o> ^name load-action-model)
   (<s> ^operator <o> + =)
}

sp {light-processing*apply*load-action-model
   (state <s> ^superstate nil
              ^operator <o>
              ^kg-url <kg-url>
              ^iteration <iteration>)
   (<o> ^name load-action-model)
-->
   (print-action |[light-processing] APPLY load-action-model from KG=| <kg-url> | iteration=| <iteration>)

   (<a1> ^device L1
         ^activate true
         ^available (kg-action-field <kg-url> |L1| true |available|)
         ^name (kg-action-field <kg-url> |L1| true |name|)
         ^method (kg-action-field <kg-url> |L1| true |method|)
         ^url (kg-action-field <kg-url> |L1| true |url|)
         ^body (kg-action-field <kg-url> |L1| true |body|)
         ^pre-attribute (kg-action-field <kg-url> |L1| true |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |L1| true |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |L1| true |post-attribute|)
         ^post-value (kg-action-field <kg-url> |L1| true |post-value|)
         ^zone (kg-action-field <kg-url> |L1| true |zone|)
         ^effect (kg-action-field <kg-url> |L1| true |effect|)
         ^control (kg-action-field <kg-url> |L1| true |control|))

   (<a2> ^device L1
         ^activate false
         ^available (kg-action-field <kg-url> |L1| false |available|)
         ^name (kg-action-field <kg-url> |L1| false |name|)
         ^method (kg-action-field <kg-url> |L1| false |method|)
         ^url (kg-action-field <kg-url> |L1| false |url|)
         ^body (kg-action-field <kg-url> |L1| false |body|)
         ^pre-attribute (kg-action-field <kg-url> |L1| false |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |L1| false |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |L1| false |post-attribute|)
         ^post-value (kg-action-field <kg-url> |L1| false |post-value|)
         ^zone (kg-action-field <kg-url> |L1| false |zone|)
         ^effect (kg-action-field <kg-url> |L1| false |effect|)
         ^control (kg-action-field <kg-url> |L1| false |control|))

   (<a3> ^device L2
         ^activate true
         ^available (kg-action-field <kg-url> |L2| true |available|)
         ^name (kg-action-field <kg-url> |L2| true |name|)
         ^method (kg-action-field <kg-url> |L2| true |method|)
         ^url (kg-action-field <kg-url> |L2| true |url|)
         ^body (kg-action-field <kg-url> |L2| true |body|)
         ^pre-attribute (kg-action-field <kg-url> |L2| true |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |L2| true |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |L2| true |post-attribute|)
         ^post-value (kg-action-field <kg-url> |L2| true |post-value|)
         ^zone (kg-action-field <kg-url> |L2| true |zone|)
         ^effect (kg-action-field <kg-url> |L2| true |effect|)
         ^control (kg-action-field <kg-url> |L2| true |control|))

   (<a4> ^device L2
         ^activate false
         ^available (kg-action-field <kg-url> |L2| false |available|)
         ^name (kg-action-field <kg-url> |L2| false |name|)
         ^method (kg-action-field <kg-url> |L2| false |method|)
         ^url (kg-action-field <kg-url> |L2| false |url|)
         ^body (kg-action-field <kg-url> |L2| false |body|)
         ^pre-attribute (kg-action-field <kg-url> |L2| false |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |L2| false |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |L2| false |post-attribute|)
         ^post-value (kg-action-field <kg-url> |L2| false |post-value|)
         ^zone (kg-action-field <kg-url> |L2| false |zone|)
         ^effect (kg-action-field <kg-url> |L2| false |effect|)
         ^control (kg-action-field <kg-url> |L2| false |control|))

   (<a5> ^device B1
         ^activate true
         ^available (kg-action-field <kg-url> |B1| true |available|)
         ^name (kg-action-field <kg-url> |B1| true |name|)
         ^method (kg-action-field <kg-url> |B1| true |method|)
         ^url (kg-action-field <kg-url> |B1| true |url|)
         ^body (kg-action-field <kg-url> |B1| true |body|)
         ^pre-attribute (kg-action-field <kg-url> |B1| true |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |B1| true |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |B1| true |post-attribute|)
         ^post-value (kg-action-field <kg-url> |B1| true |post-value|)
         ^zone (kg-action-field <kg-url> |B1| true |zone|)
         ^effect (kg-action-field <kg-url> |B1| true |effect|)
         ^control (kg-action-field <kg-url> |B1| true |control|))

   (<a6> ^device B1
         ^activate false
         ^available (kg-action-field <kg-url> |B1| false |available|)
         ^name (kg-action-field <kg-url> |B1| false |name|)
         ^method (kg-action-field <kg-url> |B1| false |method|)
         ^url (kg-action-field <kg-url> |B1| false |url|)
         ^body (kg-action-field <kg-url> |B1| false |body|)
         ^pre-attribute (kg-action-field <kg-url> |B1| false |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |B1| false |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |B1| false |post-attribute|)
         ^post-value (kg-action-field <kg-url> |B1| false |post-value|)
         ^zone (kg-action-field <kg-url> |B1| false |zone|)
         ^effect (kg-action-field <kg-url> |B1| false |effect|)
         ^control (kg-action-field <kg-url> |B1| false |control|))

   (<a7> ^device B2
         ^activate true
         ^available (kg-action-field <kg-url> |B2| true |available|)
         ^name (kg-action-field <kg-url> |B2| true |name|)
         ^method (kg-action-field <kg-url> |B2| true |method|)
         ^url (kg-action-field <kg-url> |B2| true |url|)
         ^body (kg-action-field <kg-url> |B2| true |body|)
         ^pre-attribute (kg-action-field <kg-url> |B2| true |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |B2| true |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |B2| true |post-attribute|)
         ^post-value (kg-action-field <kg-url> |B2| true |post-value|)
         ^zone (kg-action-field <kg-url> |B2| true |zone|)
         ^effect (kg-action-field <kg-url> |B2| true |effect|)
         ^control (kg-action-field <kg-url> |B2| true |control|))

   (<a8> ^device B2
         ^activate false
         ^available (kg-action-field <kg-url> |B2| false |available|)
         ^name (kg-action-field <kg-url> |B2| false |name|)
         ^method (kg-action-field <kg-url> |B2| false |method|)
         ^url (kg-action-field <kg-url> |B2| false |url|)
         ^body (kg-action-field <kg-url> |B2| false |body|)
         ^pre-attribute (kg-action-field <kg-url> |B2| false |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |B2| false |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |B2| false |post-attribute|)
         ^post-value (kg-action-field <kg-url> |B2| false |post-value|)
         ^zone (kg-action-field <kg-url> |B2| false |zone|)
         ^effect (kg-action-field <kg-url> |B2| false |effect|)
         ^control (kg-action-field <kg-url> |B2| false |control|))

   (<s> ^action <a1>
        ^action <a2>
        ^action <a3>
        ^action <a4>
        ^action <a5>
        ^action <a6>
        ^action <a7>
        ^action <a8>
        ^action-model-loaded true
        ^needs-refresh true)

   (<s> ^iteration <iteration> -)
   (<s> ^iteration (+ <iteration> 1))
}

###############################################################################
# Normalize KG action vocabulary to local percept vocabulary
###############################################################################

sp {light-processing*normalize*zone-z1-upper
   (state <s> ^action <a>)
   (<a> ^zone Z1)
-->
   (<a> ^zone-local Z1)
}

sp {light-processing*normalize*zone-z1-lower
   (state <s> ^action <a>)
   (<a> ^zone z1)
-->
   (<a> ^zone-local Z1)
}

sp {light-processing*normalize*zone-z2-upper
   (state <s> ^action <a>)
   (<a> ^zone Z2)
-->
