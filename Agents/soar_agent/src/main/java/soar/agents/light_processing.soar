###############################################################################
# Config completion and config abandonment.
###############################################################################

sp {light-processing*propose*config-complete
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^current-config <cfg>
              ^percepts <p>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<cfg> ^config-id <id>
          ^rank <rank>
          ^l1 <l1>
          ^l2 <l2>
          ^b1 <b1>
          ^b2 <b2>)
   (<p> ^z1light <l1>
        ^z2light <l2>
        ^z1blinds <b1>
        ^z2blinds <b2>)
-->
   (print-action |[light-processing] PROPOSE config-complete: id=| <id>)
   (<o> ^name config-complete
        ^config <cfg>
        ^config-id <id>
        ^rank <rank>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*complete-goal-over-config-complete
   (state <s> ^superstate nil
              ^operator <complete> +
              ^operator <cfg> +)
   (<complete> ^name complete-goal)
   (<cfg> ^name config-complete)
-->
   (print-action |[light-processing] PREFERENCE: complete-goal over config-complete|)
   (<s> ^operator <complete> > <cfg>)
}

sp {light-processing*prefer*config-complete-over-wait-for-quiescence
   (state <s> ^superstate nil
              ^operator <cfg> +
              ^operator <wait> +)
   (<cfg> ^name config-complete)
   (<wait> ^name wait-for-quiescence)
-->
   (print-action |[light-processing] PREFERENCE: config-complete over wait-for-quiescence|)
   (<s> ^operator <cfg> > <wait>)
}

sp {light-processing*apply*config-complete
   (state <s> ^superstate nil
              ^operator <o>
              ^next-config-rank <rank>)
   (<o> ^name config-complete
        ^config <cfg>
        ^config-id <id>
        ^rank <rank>)
-->
   (print-action |[light-processing] APPLY config-complete: tried id=| <id> |; refreshing before next config|)
   (<cfg> ^tried true)
   (<s> ^current-config <cfg> -
        ^next-config-rank <rank> -
        ^next-config-rank (+ <rank> 1)
        ^needs-refresh true)
}

# Disabled mismatch: abandon the whole current config immediately.
sp {light-processing*propose*abandon-current-config-l1-disabled
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^current-config <cfg>
              ^percepts <p>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<cfg> ^config-id <id>
          ^rank <rank>
          ^l1 <desired>)
   (<p> ^z1light { <current> <> <desired> }
        ^l1-status false)
-->
   (print-action |[light-processing] PROPOSE abandon-current-config: id=| <id> | reason=L1-disabled|)
   (<o> ^name abandon-current-config
        ^reason disabled
        ^device L1
        ^config <cfg>
        ^config-id <id>
        ^rank <rank>)
   (<s> ^operator <o> + =)
}

