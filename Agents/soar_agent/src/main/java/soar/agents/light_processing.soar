   (<p> ^z1d { <z1d> > <goal-z1> })
-->
   (print-action |[light-processing] PROPOSE fail-goal: Z1 needs decrease, but no applicable action was proposed|)
   (<o> ^name fail-goal
        ^reason no-applicable-action
        ^event-id <event-id>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>)
