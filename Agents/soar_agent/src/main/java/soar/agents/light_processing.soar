###############################################################################
# Refresh raw percepts from the KG
###############################################################################

sp {light-processing*propose*refresh-kg-initial
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^action-model-loaded true
              ^iteration { <iteration> < <max> }
              ^max-iterations <max>
              -^percepts-ready true
              -^raw-percepts-ready true)
-->
   (print-action |[light-processing] PROPOSE refresh-kg: initial percepts missing|)
   (<o> ^name refresh-kg
        ^reason initial-percepts-missing)
   (<s> ^operator <o> + =)
}

sp {light-processing*propose*refresh-kg-needed
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^action-model-loaded true
              ^needs-refresh true
              ^iteration { <iteration> < <max> }
              ^max-iterations <max>
              -^raw-percepts-ready true)
-->
   (print-action |[light-processing] PROPOSE refresh-kg: refresh requested|)
   (<o> ^name refresh-kg
        ^reason refresh-requested)
   (<s> ^operator <o> + =)
}

sp {light-processing*remove-old-percepts-during-refresh
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <old>)
   (<o> ^name refresh-kg)
-->
   (print-action |[light-processing] REMOVE old percept object before KG refresh|)
   (<s> ^percepts <old> -)
}

sp {light-processing*remove-percepts-ready-during-refresh
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts-ready true)
   (<o> ^name refresh-kg)
-->
   (print-action |[light-processing] REMOVE percepts-ready during KG refresh|)
   (<s> ^percepts-ready true -)
}

sp {light-processing*remove-raw-percepts-ready-during-refresh
   (state <s> ^superstate nil
              ^operator <o>
              ^raw-percepts-ready true)
   (<o> ^name refresh-kg)
-->
   (print-action |[light-processing] REMOVE raw-percepts-ready during KG refresh|)
   (<s> ^raw-percepts-ready true -)
}

sp {light-processing*apply*refresh-kg
   (state <s> ^superstate nil
              ^operator <o>
              ^kg-url <kg-url>
              ^iteration <iteration>)
   (<o> ^name refresh-kg
        ^reason <reason>)
-->
   (print-action |[light-processing] APPLY refresh-kg: reason=| <reason> | iteration=| <iteration>)

   (<p> ^z1level (kg-value <kg-url> |hasZ1Level|)
        ^z2level (kg-value <kg-url> |hasZ2Level|)
        ^z1light (kg-value <kg-url> |hasZ1Light|)
        ^z2light (kg-value <kg-url> |hasZ2Light|)
        ^z1blinds (kg-value <kg-url> |hasZ1Blinds|)
        ^z2blinds (kg-value <kg-url> |hasZ2Blinds|)
        ^l1-status (kg-value <kg-url> |L1Status|)
        ^l2-status (kg-value <kg-url> |L2Status|)
        ^b1-status (kg-value <kg-url> |B1Status|)
        ^b2-status (kg-value <kg-url> |B2Status|)
        ^sunshine (kg-value <kg-url> |hasSunshine|))

   (<s> ^percepts <p>
        ^raw-percepts-ready true)

   (<s> ^needs-refresh true -)

   (<s> ^iteration <iteration> -)
   (<s> ^iteration (+ <iteration> 1))
}

###############################################################################
# Discretize raw percepts
#
# This must be an operator application, not a self-negating elaboration.
###############################################################################

sp {light-processing*propose*discretize-percepts
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^raw-percepts-ready true
              ^percepts <p>
              -^percepts-ready true)
   (<p> ^z1level <z1level>
        ^z2level <z2level>)
   -(<p> ^z1d <z1d>)
   -(<p> ^z2d <z2d>)
-->
   (print-action |[light-processing] PROPOSE discretize-percepts: z1level=| <z1level> | z2level=| <z2level>)
   (<o> ^name discretize-percepts
        ^z1level <z1level>
        ^z2level <z2level>)
   (<s> ^operator <o> + =)
}

sp {light-processing*prefer*discretize-over-refresh
   (state <s> ^superstate nil
              ^operator <disc> +
              ^operator <refresh> +)
   (<disc> ^name discretize-percepts)
   (<refresh> ^name refresh-kg)
-->
   (print-action |[light-processing] PREFERENCE: discretize-percepts over refresh-kg|)
   (<s> ^operator <disc> > <refresh>)
}

sp {light-processing*apply*discretize-percepts
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <p>)
   (<o> ^name discretize-percepts
        ^z1level <z1level>
        ^z2level <z2level>)
-->
   (print-action |[light-processing] APPLY discretize-percepts|)

   (<p> ^z1d (discretize-light-level <z1level>)
        ^z2d (discretize-light-level <z2level>))

   (<s> ^percepts-ready true)
   (<s> ^raw-percepts-ready true -)
}

sp {light-processing*reset-no-progress-when-z1d-changes
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <p>
              ^no-progress-retries-max <max>
              ^last-z1d <old>)
   (<o> ^name discretize-percepts)
   (<p> ^z1d <new>)
   (<new> <> <old>)
-->
   (print-action |[light-processing] RESET no-progress budget: z1d changed from | <old> | to | <new>)
   (<s> ^no-progress-retries-left <max>
        ^last-z1d <old> -
        ^last-z1d <new>)
}

sp {light-processing*store-initial-z1d
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <p>)
   (<o> ^name discretize-percepts)
   (<p> ^z1d <new>)
   -(<s> ^last-z1d <old>)
-->
   (<s> ^last-z1d <new>)
}

sp {light-processing*reset-no-progress-when-z2d-changes
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <p>
              ^no-progress-retries-max <max>
              ^last-z2d <old>)
   (<o> ^name discretize-percepts)
   (<p> ^z2d <new>)
   (<new> <> <old>)
-->
   (print-action |[light-processing] RESET no-progress budget: z2d changed from | <old> | to | <new>)
   (<s> ^no-progress-retries-left <max>
        ^last-z2d <old> -
        ^last-z2d <new>)
}

sp {light-processing*store-initial-z2d
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <p>)
   (<o> ^name discretize-percepts)
   (<p> ^z2d <new>)
   -(<s> ^last-z2d <old>)
-->
   (<s> ^last-z2d <new>)
}

###############################################################################
# Goal completion
###############################################################################

sp {light-processing*propose*complete-goal
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^goal-url <goal-url>
              ^goal-event <event-id>
              ^percepts <p>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<p> ^z1d <goal-z1>
        ^z2d <goal-z2>)
-->
   (print-action |[light-processing] PROPOSE complete-goal: achieved z1=| <goal-z1> | z2=| <goal-z2>)
   (<o> ^name complete-goal
        ^event-id <event-id>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*complete-goal
   (state <s> ^superstate nil
              ^operator <o> +)
   (<o> ^name complete-goal)
-->
   (print-action |[light-processing] PREFERENCE: complete-goal is best|)
   (<s> ^operator <o> >)
}

sp {light-processing*apply*complete-goal
   (state <s> ^superstate nil
              ^operator <o>
              ^active-goal <ag>
              ^goal-event <event-id>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^goal-url <goal-url>
              ^percepts <p>
              ^td-url <td-url>
              ^io.output-link <ol>)
   (<o> ^name complete-goal
        ^event-id <event-id>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>)
-->
   (print-action |[light-processing] APPLY complete-goal: sending done message to | <goal-url>)

   (<cmd-done> ^done true
               ^reason achieved
               ^event-id <event-id>
               ^goal-z1 <goal-z1>
               ^goal-z2 <goal-z2>
               ^url <goal-url>
               ^td-url <td-url>)
   (<ol> ^send-message <cmd-done>)

   (<s> ^active-goal <ag> -
        ^goal-event <event-id> -
        ^goal-z1 <goal-z1> -
        ^goal-z2 <goal-z2> -
        ^goal-url <goal-url> -
        ^percepts <p> -
        ^percepts-ready true -)

   (<s> ^raw-percepts-ready true -)
   (<s> ^needs-refresh true -)

   (print-action |[light-processing] APPLY complete-goal: waiting for next goal|)
}

sp {light-processing*cleanup-iteration-during-complete
   (state <s> ^superstate nil
              ^operator <o>
              ^iteration <iteration>)
   (<o> ^name complete-goal)
-->
   (<s> ^iteration <iteration> -)
}

sp {light-processing*cleanup-settle-retries-during-complete
   (state <s> ^superstate nil
              ^operator <o>
              ^settle-retries-left <retries>)
   (<o> ^name complete-goal)
-->
   (<s> ^settle-retries-left <retries> -)
}

sp {light-processing*cleanup-no-progress-retries-during-complete
   (state <s> ^superstate nil
              ^operator <o>
              ^no-progress-retries-left <retries>)
   (<o> ^name complete-goal)
-->
   (<s> ^no-progress-retries-left <retries> -)
}

sp {light-processing*cleanup-last-z1d-during-complete
   (state <s> ^superstate nil
              ^operator <o>
              ^last-z1d <old>)
   (<o> ^name complete-goal)
-->
   (<s> ^last-z1d <old> -)
}

sp {light-processing*cleanup-last-z2d-during-complete
   (state <s> ^superstate nil
              ^operator <o>
              ^last-z2d <old>)
   (<o> ^name complete-goal)
-->
   (<s> ^last-z2d <old> -)
}

###############################################################################
# Confirm pending action from KG-refreshed percepts
#
# Crucial fix:
# After confirmation, request one more refresh before planning again.
# The action postcondition may only confirm actuator state, while the next
# planning step depends on updated light-level state.
###############################################################################

sp {light-processing*propose*confirm-pending
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^pending-device <device>
              ^pending-activate <activate>
              ^pending-post-attribute <post-attribute>
              ^pending-post-value <post-value>
              ^percepts <p>
              ^percepts-ready true
              -^needs-refresh true)
   (<p> ^<post-attribute> <post-value>)
-->
   (print-action |[light-processing] PROPOSE confirm-pending: device=| <device> | activate=| <activate> | post=| <post-attribute> |=| <post-value>)
   (<o> ^name confirm-pending
        ^device <device>
        ^activate <activate>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*confirm-pending
   (state <s> ^superstate nil
              ^operator <o> +)
   (<o> ^name confirm-pending)
-->
   (print-action |[light-processing] PREFERENCE: confirm-pending is best|)
   (<s> ^operator <o> >)
}

sp {light-processing*apply*confirm-pending
   (state <s> ^superstate nil
              ^operator <o>
              ^settle-retries-max <settle-max>)
   (<o> ^name confirm-pending
        ^device <device>
        ^activate <activate>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
-->
   (print-action |[light-processing] APPLY confirm-pending: confirmed device=| <device> | activate=| <activate> |; requesting fresh KG state before next decision|)

   (<s> ^pending-device <device> -
        ^pending-activate <activate> -
        ^pending-post-attribute <post-attribute> -
        ^pending-post-value <post-value> -
        ^settle-retries-left <settle-max>
        ^needs-refresh true)
}

###############################################################################
# Allow light levels to settle after an actuator confirms before replanning or
# failing. This prevents declaring no-applicable-action on stale light levels.
###############################################################################

sp {light-processing*propose*wait-for-settle
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^settle-retries-left { <retries> > 0 }
              -^pending-device <pd>
              -^needs-refresh true)
   { (<p> ^z1d { <z1d> <> <goal-z1> })
     (<p> ^z2d { <z2d> <> <goal-z2> }) }
-->
   (print-action |[light-processing] PROPOSE wait-for-settle: remaining=| <retries>)
   (<o> ^name wait-for-settle
        ^remaining <retries>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*action-over-wait-for-settle
   (state <s> ^superstate nil
              ^operator <action> +
              ^operator <settle> +)
   (<action> ^name perform-kg-action)
   (<settle> ^name wait-for-settle)
-->
   (print-action |[light-processing] PREFERENCE: perform-kg-action over wait-for-settle|)
   (<s> ^operator <action> > <settle>)
}

sp {light-processing*prefer*wait-for-settle-over-select-config
   (state <s> ^superstate nil
              ^operator <cfg> +
              ^operator <settle> +)
   (<cfg> ^name select-config)
   (<settle> ^name wait-for-settle)
-->
   (print-action |[light-processing] PREFERENCE: wait-for-settle over select-config|)
   (<s> ^operator <settle> > <cfg>)
}

sp {light-processing*prefer*wait-for-settle-over-quiescence
   (state <s> ^superstate nil
              ^operator <settle> +
              ^operator <wait> +)
   (<settle> ^name wait-for-settle)
   (<wait> ^name wait-for-quiescence)
-->
   (print-action |[light-processing] PREFERENCE: wait-for-settle over wait-for-quiescence|)
   (<s> ^operator <settle> > <wait>)
}

sp {light-processing*prefer*wait-for-settle-over-config-complete
   (state <s> ^superstate nil
              ^operator <settle> +
              ^operator <cfg> +)
   (<settle> ^name wait-for-settle)
   (<cfg> ^name config-complete)
-->
   (print-action |[light-processing] PREFERENCE: wait-for-settle over config-complete|)
   (<s> ^operator <settle> > <cfg>)
}

sp {light-processing*apply*wait-for-settle
   (state <s> ^superstate nil
              ^operator <o>
              ^settle-retries-left <retries>)
   (<o> ^name wait-for-settle
        ^remaining <retries>)
-->
   (print-action |[light-processing] APPLY wait-for-settle: remaining=| <retries> |; waiting for light level to settle|)
   (wait 200)
   (<s> ^settle-retries-left <retries> -)
   (<s> ^settle-retries-left (+ <retries> -1))
   (<s> ^needs-refresh true)
}

###############################################################################
# If no action is currently applicable, allow a bounded number of additional
# refreshes. Once the budget is exhausted, keep refreshing until max iterations.
# This lets temporarily disabled blinds become available again before failure.
###############################################################################

sp {light-processing*propose*wait-for-quiescence
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^percepts <p>
              ^percepts-ready true
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^no-progress-retries-left <retries>
              -^pending-device <pd>
              -^needs-refresh true)
   { (<p> ^z1d { <z1d> <> <goal-z1> })
     (<p> ^z2d { <z2d> <> <goal-z2> }) }
   -{ (<s> ^operator <action>)
      (<action> ^name perform-kg-action) }
-->
   (print-action |[light-processing] PROPOSE wait-for-quiescence: no applicable action, remaining=| <retries>)
   (<o> ^name wait-for-quiescence
        ^remaining <retries>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*action-over-wait-for-quiescence
   (state <s> ^superstate nil
              ^operator <action> +
              ^operator <wait> +)
   (<action> ^name perform-kg-action)
   (<wait> ^name wait-for-quiescence)
-->
   (print-action |[light-processing] PREFERENCE: perform-kg-action over wait-for-quiescence|)
   (<s> ^operator <action> > <wait>)
}

sp {light-processing*apply*wait-for-quiescence-with-budget
   (state <s> ^superstate nil
              ^operator <o>
              ^no-progress-retries-left { <retries> > 0 })
   (<o> ^name wait-for-quiescence
        ^remaining <retries>)
-->
   (print-action |[light-processing] APPLY wait-for-quiescence: remaining=| <retries> |; waiting for no-progress snapshot to resolve|)
   (wait 200)
   (<s> ^no-progress-retries-left <retries> -)
   (<s> ^no-progress-retries-left (+ <retries> -1))
   (<s> ^needs-refresh true)
}

sp {light-processing*apply*wait-for-quiescence-exhausted
   (state <s> ^superstate nil
              ^operator <o>
              ^no-progress-retries-left 0)
   (<o> ^name wait-for-quiescence
        ^remaining 0)
-->
   (print-action |[light-processing] APPLY wait-for-quiescence: remaining=0; continuing until max iterations|)
   (wait 200)
   (<s> ^needs-refresh true)
}

###############################################################################
# If a device becomes disabled while an action is pending, clear the pending
# action and keep retrying through normal planning/refresh cycles.
###############################################################################

sp {light-processing*propose*clear-pending-disabled-l1
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^pending-device L1
              ^percepts <p>
              ^percepts-ready true
              -^needs-refresh true)
   (<p> ^l1-status false)
-->
   (print-action |[light-processing] PROPOSE clear-pending-disabled: device=L1|)
   (<o> ^name clear-pending-disabled
        ^device L1)
   (<s> ^operator <o> +)
}

sp {light-processing*propose*clear-pending-disabled-l2
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^pending-device L2
              ^percepts <p>
              ^percepts-ready true
              -^needs-refresh true)
   (<p> ^l2-status false)
-->
   (print-action |[light-processing] PROPOSE clear-pending-disabled: device=L2|)
   (<o> ^name clear-pending-disabled
        ^device L2)
   (<s> ^operator <o> +)
}

sp {light-processing*propose*clear-pending-disabled-b1
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^pending-device B1
              ^percepts <p>
              ^percepts-ready true
              -^needs-refresh true)
   (<p> ^b1-status false)
-->
   (print-action |[light-processing] PROPOSE clear-pending-disabled: device=B1|)
   (<o> ^name clear-pending-disabled
        ^device B1)
   (<s> ^operator <o> +)
}

sp {light-processing*propose*clear-pending-disabled-b2
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^pending-device B2
              ^percepts <p>
              ^percepts-ready true
              -^needs-refresh true)
   (<p> ^b2-status false)
-->
   (print-action |[light-processing] PROPOSE clear-pending-disabled: device=B2|)
   (<o> ^name clear-pending-disabled
        ^device B2)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*clear-pending-disabled
   (state <s> ^superstate nil
              ^operator <o> +)
   (<o> ^name clear-pending-disabled)
-->
   (print-action |[light-processing] PREFERENCE: clear-pending-disabled is best|)
   (<s> ^operator <o> >)
}

sp {light-processing*apply*clear-pending-disabled
   (state <s> ^superstate nil
              ^operator <o>
              ^pending-device <device>
              ^pending-activate <activate>
              ^pending-post-attribute <post-attribute>
              ^pending-post-value <post-value>
              ^no-progress-retries-max <no-progress-max>)
   (<o> ^name clear-pending-disabled
        ^device <device>)
-->
   (print-action |[light-processing] APPLY clear-pending-disabled: device=| <device> | disabled; clearing pending action and retrying later|)
   (<s> ^pending-device <device> -
        ^pending-activate <activate> -
        ^pending-post-attribute <post-attribute> -
        ^pending-post-value <post-value> -
        ^no-progress-retries-left <no-progress-max>
        ^needs-refresh true)
}

###############################################################################
# Wait for feedback if a pending action has not yet appeared in the KG state
###############################################################################

sp {light-processing*propose*wait-for-feedback
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^pending-device <device>
              ^pending-post-attribute <post-attribute>
              ^pending-post-value <post-value>
              ^percepts <p>
              ^percepts-ready true
              -^needs-refresh true)
   -(<p> ^<post-attribute> <post-value>)
-->
   (print-action |[light-processing] PROPOSE wait-for-feedback: pending device=| <device>)
   (<o> ^name wait-for-feedback
        ^device <device>)
   (<s> ^operator <o> + =)
}

sp {light-processing*apply*wait-for-feedback
   (state <s> ^superstate nil
              ^operator <o>)
   (<o> ^name wait-for-feedback
        ^device <device>)
-->
   (print-action |[light-processing] APPLY wait-for-feedback: device=| <device>)
   (wait 100)
   (<s> ^needs-refresh true)
}

###############################################################################
# Explicit on/off configuration search
#
# Strategy:
# - Heuristic actions are tried first when directly applicable.
# - If no heuristic action can make progress, try concrete assignments for
#   L1/L2/B1/B2.
# - If the current config requires a disabled or otherwise blocked device,
#   abandon the whole config with one operator: abandon-current-config.
# - If all configurations have been tried, reset the tried marks and start over.
#   This lets the agent recover if the environment changes, e.g., blinds become
#   available again.
# - The only final failure condition is the global max-iteration rule.
###############################################################################

sp {light-processing*propose*select-config
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^config-search-loaded true
              ^config <cfg>
              ^next-config-rank <rank>
              ^percepts-ready true
              ^iteration { <iteration> < <max> }
              ^max-iterations <max>
              -^current-config <current>
              -^pending-device <pd>
              -^needs-refresh true)
   (<cfg> ^config-id <id>
          ^rank <rank>
          -^tried true)
-->
   (print-action |[light-processing] PROPOSE select-config: id=| <id> | rank=| <rank>)
   (<o> ^name select-config
        ^config <cfg>
        ^config-id <id>
        ^rank <rank>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*heuristic-action-over-select-config-increase
   (state <s> ^superstate nil
              ^operator <action> +
              ^operator <cfg> +)
   (<action> ^name perform-kg-action
             ^effect increase)
   (<cfg> ^name select-config)
-->
   (print-action |[light-processing] PREFERENCE: heuristic increase action over select-config|)
   (<s> ^operator <action> > <cfg>)
}

sp {light-processing*prefer*heuristic-action-over-select-config-decrease
   (state <s> ^superstate nil
              ^operator <action> +
              ^operator <cfg> +)
   (<action> ^name perform-kg-action
             ^effect decrease)
   (<cfg> ^name select-config)
-->
   (print-action |[light-processing] PREFERENCE: heuristic decrease action over select-config|)
   (<s> ^operator <action> > <cfg>)
}

sp {light-processing*prefer*select-config-over-quiescence
   (state <s> ^superstate nil
              ^operator <cfg> +
              ^operator <wait> +)
   (<cfg> ^name select-config)
   (<wait> ^name wait-for-quiescence)
-->
   (print-action |[light-processing] PREFERENCE: select-config over wait-for-quiescence|)
   (<s> ^operator <cfg> > <wait>)
}

sp {light-processing*apply*select-config
   (state <s> ^superstate nil
              ^operator <o>
              ^settle-retries-left <retries>)
   (<o> ^name select-config
        ^config <cfg>
        ^config-id <id>)
-->
   (print-action |[light-processing] APPLY select-config: id=| <id>)
   (<s> ^current-config <cfg>
        ^settle-retries-left <retries> -)
}

sp {light-processing*apply*select-config-no-settle
   (state <s> ^superstate nil
              ^operator <o>
              -^settle-retries-left <retries>)
   (<o> ^name select-config
        ^config <cfg>
        ^config-id <id>)
-->
   (print-action |[light-processing] APPLY select-config: id=| <id>)
   (<s> ^current-config <cfg>)
}

###############################################################################
# Config-search actions: perform the first executable mismatch in a fixed order.
###############################################################################

sp {light-processing*propose*config-action-l1
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^current-config <cfg>
              ^percepts <p>
              ^action <a>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<cfg> ^l1 <desired>)
   (<p> ^z1light { <current> <> <desired> }
        ^l1-status true)
   (<a> ^available true
        ^device L1
        ^activate <desired>
        ^pre-local <pre-attribute>
        ^pre-value <pre-value>
        ^post-local <post-attribute>
        ^post-value <post-value>
        ^name <action-name>
        ^method <method>
        ^url <url>
        ^body <body>
        ^control-local <control>)
   (<p> ^<pre-attribute> <pre-value>)
-->
   (print-action |[light-processing] PROPOSE config action: L1 -> | <desired> | via | <action-name>)
   (<o> ^name perform-kg-action
        ^source config-search
        ^action-name <action-name>
        ^zone Z1
        ^effect set
        ^control <control>
        ^device L1
        ^activate <desired>
        ^method <method>
        ^url <url>
        ^body <body>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
   (<s> ^operator <o> +)
}

sp {light-processing*propose*config-action-l2
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^current-config <cfg>
              ^percepts <p>
              ^action <a>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<cfg> ^l2 <desired>)
   (<p> ^z2light { <current> <> <desired> }
        ^l2-status true)
   (<a> ^available true
        ^device L2
        ^activate <desired>
        ^pre-local <pre-attribute>
        ^pre-value <pre-value>
        ^post-local <post-attribute>
        ^post-value <post-value>
        ^name <action-name>
        ^method <method>
        ^url <url>
        ^body <body>
        ^control-local <control>)
   (<p> ^<pre-attribute> <pre-value>)
-->
   (print-action |[light-processing] PROPOSE config action: L2 -> | <desired> | via | <action-name>)
   (<o> ^name perform-kg-action
        ^source config-search
        ^action-name <action-name>
        ^zone Z2
        ^effect set
        ^control <control>
        ^device L2
