        ^pre-local <pre-attribute>
        ^pre-value <pre-value>
        ^post-local <post-attribute>
        ^post-value <post-value>
        ^device <device>
        ^activate <activate>
        ^name <action-name>
        ^method <method>
        ^url <url>
        ^body <body>
        ^control-local <control>
        ^status-local <status-attribute>)
   (<p> ^<pre-attribute> <pre-value>
        ^<status-attribute> true)
-->
   (print-action |[light-processing] PROPOSE Z2 decrease: z2d=| <z2d> | goal=| <goal-z2> | action=| <action-name> | control=| <control>)
   (<o> ^name perform-kg-action
        ^action-name <action-name>
        ^zone Z2
        ^effect decrease
        ^control <control>
        ^device <device>
        ^activate <activate>
        ^method <method>
        ^url <url>
        ^body <body>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
   (<s> ^operator <o> +)
}

###############################################################################
# Top-state action selection preferences
###############################################################################

sp {light-processing*prefer*z1-blinds-over-light-when-both-need-increase
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> < <goal-z1> }
        ^z2d { <z2d> < <goal-z2> })
   (<o1> ^name perform-kg-action
         ^effect increase
         ^zone Z1
         ^control blinds
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^effect increase
         ^zone Z1
         ^control light
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: both zones need increase, prefer Z1 blinds over light; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*z2-blinds-over-light-when-both-need-increase
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> < <goal-z1> }
        ^z2d { <z2d> < <goal-z2> })
   (<o1> ^name perform-kg-action
         ^effect increase
         ^zone Z2
         ^control blinds
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^effect increase
         ^zone Z2
         ^control light
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: both zones need increase, prefer Z2 blinds over light; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*z1-blinds-over-light-when-z2-not-high
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> < <goal-z1> }
        ^z2d { <z2d> <= <goal-z2> })
   (<o1> ^name perform-kg-action
         ^effect increase
         ^zone Z1
         ^control blinds
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^effect increase
         ^zone Z1
         ^control light
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: Z2 not high, prefer Z1 blinds over light; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*z2-blinds-over-light-when-z1-not-high
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z2d { <z2d> < <goal-z2> }
        ^z1d { <z1d> <= <goal-z1> })
   (<o1> ^name perform-kg-action
         ^effect increase
         ^zone Z2
         ^control blinds
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^effect increase
         ^zone Z2
         ^control light
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: Z1 not high, prefer Z2 blinds over light; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*decrease*light-over-blinds
   (state <s> ^superstate nil
              ^operator <o1> +
              ^operator <o2> +)
   (<o1> ^name perform-kg-action
         ^effect decrease
         ^zone <zone>
         ^control light
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^effect decrease
         ^zone <zone>
         ^control blinds
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: decrease in same zone, prefer light over blinds; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

# In mixed states, prefer improving the too-low zone before repairing the
# too-high zone. This avoids oscillating on a coupled actuator like B1.
sp {light-processing*prefer*z2-increase-over-z1-decrease
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> > <goal-z1> }
        ^z2d { <z2d> < <goal-z2> })
   (<o1> ^name perform-kg-action
         ^zone Z1
         ^effect decrease
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^zone Z2
         ^effect increase
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: mixed state, prefer Z2 increase over Z1 decrease; prefer | <n2> | over | <n1>)
   (<s> ^operator <o2> > <o1>)
}

sp {light-processing*prefer*z1-increase-over-z2-decrease
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> < <goal-z1> }
        ^z2d { <z2d> > <goal-z2> })
   (<o1> ^name perform-kg-action
         ^zone Z1
         ^effect increase
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^zone Z2
         ^effect decrease
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: mixed state, prefer Z1 increase over Z2 decrease; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

# When one zone is already above goal and the other still needs more light,
# prefer the artificial light action in the low zone over opening more blinds.
sp {light-processing*prefer*z2-light-over-z2-blinds-when-z1-high
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> > <goal-z1> }
        ^z2d { <z2d> < <goal-z2> })
   (<o1> ^name perform-kg-action
         ^zone Z2
         ^effect increase
         ^control light
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^zone Z2
         ^effect increase
         ^control blinds
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: Z1 already high, prefer Z2 light over blinds; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*z1-light-over-z1-blinds-when-z2-high
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> < <goal-z1> }
        ^z2d { <z2d> > <goal-z2> })
   (<o1> ^name perform-kg-action
         ^zone Z1
         ^effect increase
         ^control light
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^zone Z1
         ^effect increase
         ^control blinds
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: Z2 already high, prefer Z1 light over blinds; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*z1-over-z2-when-both-need-increase
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> < <goal-z1> }
        ^z2d { <z2d> < <goal-z2> })
   (<o1> ^name perform-kg-action
         ^zone Z1
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^zone Z2
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: both zones need increase, prefer Z1 over Z2; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*z1-over-z2-when-both-need-decrease
   (state <s> ^superstate nil
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^percepts-ready true
              ^operator <o1> +
              ^operator <o2> +)
   (<p> ^z1d { <z1d> > <goal-z1> }
        ^z2d { <z2d> > <goal-z2> })
   (<o1> ^name perform-kg-action
         ^zone Z1
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^zone Z2
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: both zones need decrease, prefer Z1 over Z2; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

###############################################################################
# Apply selected KG action
###############################################################################

sp {light-processing*apply*kg-action
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^operator <o>
              ^headers <headers>
              ^iteration <iteration>
              ^no-progress-retries-max <no-progress-max>
              ^io.output-link <ol>)
   (<o> ^name perform-kg-action
        ^action-name <action-name>
        ^device <device>
        ^activate <activate>
        ^method <method>
        ^url <url>
        ^body <body>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
-->
   (print-action |[light-processing] APPLY KG action: | <action-name> | device=| <device> | activate=| <activate> | url=| <url> | body=| <body> | iteration=| <iteration>)

   (<req> ^method <method>
          ^url <url>
          ^headers <headers>
          ^payload <body>)

   (<ol> ^send-http-request <req>)

   (<s> ^pending-device <device>
        ^pending-activate <activate>
        ^pending-post-attribute <post-attribute>
        ^pending-post-value <post-value>
        ^no-progress-retries-left <no-progress-max>
        ^needs-refresh true)

   (<s> ^iteration <iteration> -)
   (<s> ^iteration (+ <iteration> 1))
}

###############################################################################
# Diagnostic fallback operators
#
# No-applicable-action is treated as a transient condition. The agent keeps
# waiting and refreshing until a real action becomes available again or the
# max-iterations failure rule fires.
###############################################################################

###############################################################################
# Output-link cleanup
#
# The Java output handler should add:
#   ^status complete
# to command objects after executing them.
###############################################################################

sp {light-processing*cleanup*completed-http-request
   (state <s> ^superstate nil
              ^io.output-link <ol>)
   (<ol> ^send-http-request <req>)
   (<req> ^status complete)
-->
   (print-action |[light-processing] CLEANUP completed HTTP request|)
   (<ol> ^send-http-request <req> -)
}

sp {light-processing*cleanup*completed-register-profile
   (state <s> ^superstate nil
              ^io.output-link <ol>)
   (<ol> ^register-profile <cmd>)
   (<cmd> ^status complete)
-->
   (print-action |[light-processing] CLEANUP completed register-profile command|)
   (<ol> ^register-profile <cmd> -)
}

sp {light-processing*cleanup*completed-send-message
   (state <s> ^superstate nil
              ^io.output-link <ol>)
   (<ol> ^send-message <cmd>)
   (<cmd> ^status complete)
-->
   (print-action |[light-processing] CLEANUP completed send-message command|)
   (<ol> ^send-message <cmd> -)
}
