###############################################################################
# Refresh raw percepts from the KG
###############################################################################

sp {light-processing*propose*refresh-kg-initial
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^action-model-loaded true
              ^iteration { <iteration> < <max> }
              ^max-iterations <max>
              -^percepts-ready true
              -^raw-percepts-ready true)
-->
   (print-action |[light-processing] PROPOSE refresh-kg: initial percepts missing|)
   (<o> ^name refresh-kg
        ^reason initial-percepts-missing)
   (<s> ^operator <o> + =)
}

sp {light-processing*propose*refresh-kg-needed
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^action-model-loaded true
              ^needs-refresh true
              ^iteration { <iteration> < <max> }
              ^max-iterations <max>
              -^raw-percepts-ready true)
-->
   (print-action |[light-processing] PROPOSE refresh-kg: refresh requested|)
   (<o> ^name refresh-kg
        ^reason refresh-requested)
   (<s> ^operator <o> + =)
}

sp {light-processing*remove-old-percepts-during-refresh
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <old>)
   (<o> ^name refresh-kg)
-->
   (print-action |[light-processing] REMOVE old percept object before KG refresh|)
   (<s> ^percepts <old> -)
}

sp {light-processing*remove-percepts-ready-during-refresh
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts-ready true)
   (<o> ^name refresh-kg)
-->
   (print-action |[light-processing] REMOVE percepts-ready during KG refresh|)
   (<s> ^percepts-ready true -)
}

sp {light-processing*remove-raw-percepts-ready-during-refresh
   (state <s> ^superstate nil
              ^operator <o>
              ^raw-percepts-ready true)
   (<o> ^name refresh-kg)
-->
   (print-action |[light-processing] REMOVE raw-percepts-ready during KG refresh|)
   (<s> ^raw-percepts-ready true -)
}

sp {light-processing*apply*refresh-kg
   (state <s> ^superstate nil
              ^operator <o>
              ^kg-url <kg-url>
              ^iteration <iteration>)
   (<o> ^name refresh-kg
        ^reason <reason>)
-->
   (print-action |[light-processing] APPLY refresh-kg: reason=| <reason> | iteration=| <iteration>)

   (<p> ^z1level (kg-value <kg-url> |hasZ1Level|)
        ^z2level (kg-value <kg-url> |hasZ2Level|)
        ^z1light (kg-value <kg-url> |hasZ1Light|)
        ^z2light (kg-value <kg-url> |hasZ2Light|)
        ^z1blinds (kg-value <kg-url> |hasZ1Blinds|)
        ^z2blinds (kg-value <kg-url> |hasZ2Blinds|)
        ^l1-status (kg-value <kg-url> |L1Status|)
        ^l2-status (kg-value <kg-url> |L2Status|)
        ^b1-status (kg-value <kg-url> |B1Status|)
        ^b2-status (kg-value <kg-url> |B2Status|)
        ^sunshine (kg-value <kg-url> |hasSunshine|))

   (<s> ^percepts <p>
        ^raw-percepts-ready true)

   (<s> ^needs-refresh true -)

   (<s> ^iteration <iteration> -)
   (<s> ^iteration (+ <iteration> 1))
}

###############################################################################
# Discretize raw percepts
#
# This must be an operator application, not a self-negating elaboration.
###############################################################################

sp {light-processing*propose*discretize-percepts
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^raw-percepts-ready true
              ^percepts <p>
              -^percepts-ready true)
   (<p> ^z1level <z1level>
        ^z2level <z2level>)
   -(<p> ^z1d <z1d>)
   -(<p> ^z2d <z2d>)
-->
   (print-action |[light-processing] PROPOSE discretize-percepts: z1level=| <z1level> | z2level=| <z2level>)
   (<o> ^name discretize-percepts
        ^z1level <z1level>
        ^z2level <z2level>)
   (<s> ^operator <o> + =)
}

sp {light-processing*prefer*discretize-over-refresh
   (state <s> ^superstate nil
              ^operator <disc> +
              ^operator <refresh> +)
   (<disc> ^name discretize-percepts)
   (<refresh> ^name refresh-kg)
-->
   (print-action |[light-processing] PREFERENCE: discretize-percepts over refresh-kg|)
   (<s> ^operator <disc> > <refresh>)
}

sp {light-processing*apply*discretize-percepts
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <p>)
   (<o> ^name discretize-percepts
        ^z1level <z1level>
        ^z2level <z2level>)
-->
   (print-action |[light-processing] APPLY discretize-percepts|)

   (<p> ^z1d (discretize-light-level <z1level>)
        ^z2d (discretize-light-level <z2level>))

   (<s> ^percepts-ready true)
   (<s> ^raw-percepts-ready true -)
}

###############################################################################
# Goal completion
###############################################################################

sp {light-processing*propose*complete-goal
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^goal-url <goal-url>
              ^goal-event <event-id>
              ^percepts <p>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<p> ^z1d <goal-z1>
        ^z2d <goal-z2>)
-->
   (print-action |[light-processing] PROPOSE complete-goal: achieved z1=| <goal-z1> | z2=| <goal-z2>)
   (<o> ^name complete-goal
        ^event-id <event-id>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*complete-goal
   (state <s> ^superstate nil
              ^operator <o> +)
   (<o> ^name complete-goal)
-->
   (print-action |[light-processing] PREFERENCE: complete-goal is best|)
   (<s> ^operator <o> >)
}

sp {light-processing*apply*complete-goal
   (state <s> ^superstate nil
              ^operator <o>
              ^active-goal <ag>
              ^goal-event <event-id>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^goal-url <goal-url>
              ^percepts <p>
              ^td-url <td-url>
              ^io.output-link <ol>)
   (<o> ^name complete-goal
        ^event-id <event-id>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>)
-->
   (print-action |[light-processing] APPLY complete-goal: sending done message to | <goal-url>)

   (<cmd-done> ^done true
               ^reason achieved
               ^event-id <event-id>
               ^goal-z1 <goal-z1>
               ^goal-z2 <goal-z2>
               ^url <goal-url>
               ^td-url <td-url>)
   (<ol> ^send-message <cmd-done>)

   (<s> ^active-goal <ag> -
        ^goal-event <event-id> -
        ^goal-z1 <goal-z1> -
        ^goal-z2 <goal-z2> -
        ^goal-url <goal-url> -
        ^percepts <p> -
        ^percepts-ready true -)

   (<s> ^raw-percepts-ready true -)
   (<s> ^needs-refresh true -)

   (print-action |[light-processing] APPLY complete-goal: waiting for next goal|)
}

sp {light-processing*cleanup-iteration-during-complete
   (state <s> ^superstate nil
              ^operator <o>
              ^iteration <iteration>)
   (<o> ^name complete-goal)
-->
   (<s> ^iteration <iteration> -)
}

###############################################################################
# Confirm pending action from KG-refreshed percepts
#
# Crucial fix:
# After confirmation, request one more refresh before planning again.
# The action postcondition may only confirm actuator state, while the next
# planning step depends on updated light-level state.
###############################################################################

sp {light-processing*propose*confirm-pending
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^pending-device <device>
              ^pending-activate <activate>
              ^pending-post-attribute <post-attribute>
              ^pending-post-value <post-value>
              ^percepts <p>
              ^percepts-ready true
              -^needs-refresh true)
   (<p> ^<post-attribute> <post-value>)
-->
   (print-action |[light-processing] PROPOSE confirm-pending: device=| <device> | activate=| <activate> | post=| <post-attribute> |=| <post-value>)
   (<o> ^name confirm-pending
        ^device <device>
        ^activate <activate>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*confirm-pending
   (state <s> ^superstate nil
              ^operator <o> +)
   (<o> ^name confirm-pending)
-->
   (print-action |[light-processing] PREFERENCE: confirm-pending is best|)
   (<s> ^operator <o> >)
}

sp {light-processing*apply*confirm-pending
   (state <s> ^superstate nil
              ^operator <o>)
   (<o> ^name confirm-pending
        ^device <device>
        ^activate <activate>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
-->
   (print-action |[light-processing] APPLY confirm-pending: confirmed device=| <device> | activate=| <activate> |; requesting fresh KG state before next decision|)

   (<s> ^pending-device <device> -
        ^pending-activate <activate> -
        ^pending-post-attribute <post-attribute> -
        ^pending-post-value <post-value> -
        ^needs-refresh true)
}

###############################################################################
# Wait for feedback if a pending action has not yet appeared in the KG state
###############################################################################

sp {light-processing*propose*wait-for-feedback
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^pending-device <device>
              ^pending-post-attribute <post-attribute>
              ^pending-post-value <post-value>
              ^percepts <p>
              ^percepts-ready true
              -^needs-refresh true)
   -(<p> ^<post-attribute> <post-value>)
-->
   (print-action |[light-processing] PROPOSE wait-for-feedback: pending device=| <device>)
   (<o> ^name wait-for-feedback
        ^device <device>)
   (<s> ^operator <o> + =)
}

sp {light-processing*apply*wait-for-feedback
   (state <s> ^superstate nil
              ^operator <o>)
   (<o> ^name wait-for-feedback
        ^device <device>)
-->
   (print-action |[light-processing] APPLY wait-for-feedback: device=| <device>)
   (wait 100)
   (<s> ^needs-refresh true)
}

###############################################################################
# Candidate operators for the problem space
###############################################################################

sp {light-processing*propose*z1*increase
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^goal-z1 <goal-z1>
              ^percepts <p>
              ^action <a>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<p> ^z1d { <z1d> < <goal-z1> })
   (<a> ^available true
        ^zone-local Z1
        ^effect-local increase
        ^pre-local <pre-attribute>
        ^pre-value <pre-value>
        ^post-local <post-attribute>
        ^post-value <post-value>
        ^device <device>
        ^activate <activate>
        ^name <action-name>
        ^method <method>
        ^url <url>
        ^body <body>
        ^control-local <control>)
   (<p> ^<pre-attribute> <pre-value>)
-->
   (print-action |[light-processing] PROPOSE Z1 increase: z1d=| <z1d> | goal=| <goal-z1> | action=| <action-name> | control=| <control>)
   (<o> ^name perform-kg-action
        ^action-name <action-name>
        ^zone Z1
        ^effect increase
        ^control <control>
        ^device <device>
        ^activate <activate>
        ^method <method>
        ^url <url>
        ^body <body>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
   (<s> ^operator <o> +)
}

sp {light-processing*propose*z1*decrease
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^goal-z1 <goal-z1>
              ^percepts <p>
              ^action <a>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<p> ^z1d { <z1d> > <goal-z1> })
   (<a> ^available true
        ^zone-local Z1
        ^effect-local decrease
        ^pre-local <pre-attribute>
        ^pre-value <pre-value>
        ^post-local <post-attribute>
        ^post-value <post-value>
        ^device <device>
        ^activate <activate>
        ^name <action-name>
        ^method <method>
        ^url <url>
        ^body <body>
        ^control-local <control>)
   (<p> ^<pre-attribute> <pre-value>)
-->
   (print-action |[light-processing] PROPOSE Z1 decrease: z1d=| <z1d> | goal=| <goal-z1> | action=| <action-name> | control=| <control>)
   (<o> ^name perform-kg-action
        ^action-name <action-name>
        ^zone Z1
        ^effect decrease
        ^control <control>
        ^device <device>
        ^activate <activate>
        ^method <method>
        ^url <url>
        ^body <body>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
   (<s> ^operator <o> +)
}

sp {light-processing*propose*z2*increase
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^action <a>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<p> ^z2d { <z2d> < <goal-z2> })
   (<a> ^available true
        ^zone-local Z2
        ^effect-local increase
        ^pre-local <pre-attribute>
        ^pre-value <pre-value>
        ^post-local <post-attribute>
        ^post-value <post-value>
        ^device <device>
        ^activate <activate>
        ^name <action-name>
        ^method <method>
        ^url <url>
        ^body <body>
        ^control-local <control>)
   (<p> ^<pre-attribute> <pre-value>)
-->
   (print-action |[light-processing] PROPOSE Z2 increase: z2d=| <z2d> | goal=| <goal-z2> | action=| <action-name> | control=| <control>)
   (<o> ^name perform-kg-action
        ^action-name <action-name>
        ^zone Z2
        ^effect increase
        ^control <control>
        ^device <device>
        ^activate <activate>
        ^method <method>
        ^url <url>
        ^body <body>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
   (<s> ^operator <o> +)
}

sp {light-processing*propose*z2*decrease
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^goal-z2 <goal-z2>
              ^percepts <p>
              ^action <a>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<p> ^z2d { <z2d> > <goal-z2> })
   (<a> ^available true
        ^zone-local Z2
        ^effect-local decrease
        ^pre-local <pre-attribute>
        ^pre-value <pre-value>
        ^post-local <post-attribute>
        ^post-value <post-value>
        ^device <device>
        ^activate <activate>
        ^name <action-name>
        ^method <method>
        ^url <url>
        ^body <body>
        ^control-local <control>)
   (<p> ^<pre-attribute> <pre-value>)
-->
   (print-action |[light-processing] PROPOSE Z2 decrease: z2d=| <z2d> | goal=| <goal-z2> | action=| <action-name> | control=| <control>)
   (<o> ^name perform-kg-action
        ^action-name <action-name>
        ^zone Z2
        ^effect decrease
        ^control <control>
        ^device <device>
        ^activate <activate>
        ^method <method>
        ^url <url>
        ^body <body>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
   (<s> ^operator <o> +)
}

###############################################################################
# Top-state action selection preferences
###############################################################################

sp {light-processing*prefer*increase*blinds-over-light
   (state <s> ^superstate nil
              ^operator <o1> +
              ^operator <o2> +)
   (<o1> ^name perform-kg-action
         ^effect increase
         ^zone <zone>
         ^control blinds
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^effect increase
         ^zone <zone>
         ^control light
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: increase in same zone, prefer blinds over light; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*decrease*light-over-blinds
   (state <s> ^superstate nil
              ^operator <o1> +
              ^operator <o2> +)
   (<o1> ^name perform-kg-action
         ^effect decrease
         ^zone <zone>
         ^control light
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^effect decrease
         ^zone <zone>
         ^control blinds
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: decrease in same zone, prefer light over blinds; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

sp {light-processing*prefer*z1-over-z2
   (state <s> ^superstate nil
              ^operator <o1> +
              ^operator <o2> +)
   (<o1> ^name perform-kg-action
         ^zone Z1
         ^action-name <n1>)
   (<o2> ^name perform-kg-action
         ^zone Z2
         ^action-name <n2>)
-->
   (print-action |[light-processing] PREFERENCE: default prefer Z1 over Z2; prefer | <n1> | over | <n2>)
   (<s> ^operator <o1> > <o2>)
}

###############################################################################
# Apply selected KG action
###############################################################################

sp {light-processing*apply*kg-action
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^operator <o>
              ^headers <headers>
              ^iteration <iteration>
              ^io.output-link <ol>)
   (<o> ^name perform-kg-action
        ^action-name <action-name>
        ^device <device>
        ^activate <activate>
        ^method <method>
        ^url <url>
        ^body <body>
        ^post-attribute <post-attribute>
        ^post-value <post-value>)
-->
   (print-action |[light-processing] APPLY KG action: | <action-name> | device=| <device> | activate=| <activate> | url=| <url> | body=| <body> | iteration=| <iteration>)

   (<req> ^method <method>
          ^url <url>
          ^headers <headers>
          ^payload <body>)

   (<ol> ^send-http-request <req>)

   (<s> ^pending-device <device>
        ^pending-activate <activate>
        ^pending-post-attribute <post-attribute>
        ^pending-post-value <post-value>
        ^needs-refresh true)

   (<s> ^iteration <iteration> -)
   (<s> ^iteration (+ <iteration> 1))
}

###############################################################################
# Diagnostic fallback operators
#
# These do not repair a bad KG model, but they prevent silent stopping.
# If one of these fires, the KG action model and the percept attribute/value
# vocabulary are inconsistent for the needed direction.
###############################################################################

sp {light-processing*propose*diagnose-z1-needs-increase
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^goal-event <event-id>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^goal-url <goal-url>
              ^percepts <p>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<p> ^z1d { <z1d> < <goal-z1> })
-->
   (print-action |[light-processing] PROPOSE fail-goal: Z1 needs increase, but no applicable action was proposed|)
   (<o> ^name fail-goal
        ^reason no-applicable-action
        ^event-id <event-id>
        ^goal-z1 <goal-z1>
        ^goal-z2 <goal-z2>
        ^goal-url <goal-url>)
   (<s> ^operator <o> +)
}

sp {light-processing*propose*diagnose-z1-needs-decrease
