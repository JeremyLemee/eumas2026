# Blocked mismatch: if no config-search action is executable at all, abandon the
# whole config and move on. The + = indifferent preference prevents a tie impasse
# if several mismatches are blocked at the same time.
sp {light-processing*propose*abandon-current-config-l1-blocked
   (state <s> ^superstate nil
              ^active-goal <ag>
              ^current-config <cfg>
              ^percepts <p>
              ^percepts-ready true
              -^pending-device <pd>
              -^needs-refresh true)
   (<cfg> ^config-id <id>
          ^rank <rank>
          ^l1 <desired>)
   (<p> ^z1light { <current> <> <desired> })
   -{ (<s> ^operator <action>)
      (<action> ^name perform-kg-action
                ^source config-search) }
-->
   (print-action |[light-processing] PROPOSE abandon-current-config: id=| <id> | reason=L1-blocked|)
   (<o> ^name abandon-current-config
        ^reason blocked
        ^device L1
        ^config <cfg>
        ^config-id <id>
        ^rank <rank>)
   (<s> ^operator <o> + =)
}

