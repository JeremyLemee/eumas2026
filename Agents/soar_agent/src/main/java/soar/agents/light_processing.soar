###############################################################################
# Load the action model from the KG
###############################################################################

sp {light-processing*propose*load-action-model
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^kg-url <kg-url>
              ^iteration { <iteration> < <max> }
              ^max-iterations <max>
              -^action-model-loaded true)
-->
   (print-action |[light-processing] PROPOSE load-action-model|)
   (<o> ^name load-action-model)
   (<s> ^operator <o> + =)
}

sp {light-processing*apply*load-action-model
   (state <s> ^superstate nil
              ^operator <o>
              ^kg-url <kg-url>
              ^iteration <iteration>)
   (<o> ^name load-action-model)
-->
   (print-action |[light-processing] APPLY load-action-model from KG=| <kg-url> | iteration=| <iteration>)

   (<a1> ^device L1
         ^activate true
         ^available (kg-action-field <kg-url> |L1| true |available|)
         ^name (kg-action-field <kg-url> |L1| true |name|)
         ^method (kg-action-field <kg-url> |L1| true |method|)
         ^url (kg-action-field <kg-url> |L1| true |url|)
         ^body (kg-action-field <kg-url> |L1| true |body|)
         ^pre-attribute (kg-action-field <kg-url> |L1| true |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |L1| true |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |L1| true |post-attribute|)
         ^post-value (kg-action-field <kg-url> |L1| true |post-value|)
         ^zone (kg-action-field <kg-url> |L1| true |zone|)
         ^effect (kg-action-field <kg-url> |L1| true |effect|)
         ^control (kg-action-field <kg-url> |L1| true |control|))

   (<a2> ^device L1
         ^activate false
         ^available (kg-action-field <kg-url> |L1| false |available|)
         ^name (kg-action-field <kg-url> |L1| false |name|)
         ^method (kg-action-field <kg-url> |L1| false |method|)
         ^url (kg-action-field <kg-url> |L1| false |url|)
         ^body (kg-action-field <kg-url> |L1| false |body|)
         ^pre-attribute (kg-action-field <kg-url> |L1| false |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |L1| false |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |L1| false |post-attribute|)
         ^post-value (kg-action-field <kg-url> |L1| false |post-value|)
         ^zone (kg-action-field <kg-url> |L1| false |zone|)
         ^effect (kg-action-field <kg-url> |L1| false |effect|)
         ^control (kg-action-field <kg-url> |L1| false |control|))

   (<a3> ^device L2
         ^activate true
         ^available (kg-action-field <kg-url> |L2| true |available|)
         ^name (kg-action-field <kg-url> |L2| true |name|)
         ^method (kg-action-field <kg-url> |L2| true |method|)
         ^url (kg-action-field <kg-url> |L2| true |url|)
         ^body (kg-action-field <kg-url> |L2| true |body|)
         ^pre-attribute (kg-action-field <kg-url> |L2| true |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |L2| true |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |L2| true |post-attribute|)
         ^post-value (kg-action-field <kg-url> |L2| true |post-value|)
         ^zone (kg-action-field <kg-url> |L2| true |zone|)
         ^effect (kg-action-field <kg-url> |L2| true |effect|)
         ^control (kg-action-field <kg-url> |L2| true |control|))

   (<a4> ^device L2
         ^activate false
         ^available (kg-action-field <kg-url> |L2| false |available|)
         ^name (kg-action-field <kg-url> |L2| false |name|)
         ^method (kg-action-field <kg-url> |L2| false |method|)
         ^url (kg-action-field <kg-url> |L2| false |url|)
         ^body (kg-action-field <kg-url> |L2| false |body|)
         ^pre-attribute (kg-action-field <kg-url> |L2| false |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |L2| false |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |L2| false |post-attribute|)
         ^post-value (kg-action-field <kg-url> |L2| false |post-value|)
         ^zone (kg-action-field <kg-url> |L2| false |zone|)
         ^effect (kg-action-field <kg-url> |L2| false |effect|)
         ^control (kg-action-field <kg-url> |L2| false |control|))

   (<a5> ^device B1
         ^activate true
         ^available (kg-action-field <kg-url> |B1| true |available|)
         ^name (kg-action-field <kg-url> |B1| true |name|)
         ^method (kg-action-field <kg-url> |B1| true |method|)
         ^url (kg-action-field <kg-url> |B1| true |url|)
         ^body (kg-action-field <kg-url> |B1| true |body|)
         ^pre-attribute (kg-action-field <kg-url> |B1| true |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |B1| true |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |B1| true |post-attribute|)
         ^post-value (kg-action-field <kg-url> |B1| true |post-value|)
         ^zone (kg-action-field <kg-url> |B1| true |zone|)
         ^effect (kg-action-field <kg-url> |B1| true |effect|)
         ^control (kg-action-field <kg-url> |B1| true |control|))

   (<a6> ^device B1
         ^activate false
         ^available (kg-action-field <kg-url> |B1| false |available|)
         ^name (kg-action-field <kg-url> |B1| false |name|)
         ^method (kg-action-field <kg-url> |B1| false |method|)
         ^url (kg-action-field <kg-url> |B1| false |url|)
         ^body (kg-action-field <kg-url> |B1| false |body|)
         ^pre-attribute (kg-action-field <kg-url> |B1| false |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |B1| false |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |B1| false |post-attribute|)
         ^post-value (kg-action-field <kg-url> |B1| false |post-value|)
         ^zone (kg-action-field <kg-url> |B1| false |zone|)
         ^effect (kg-action-field <kg-url> |B1| false |effect|)
         ^control (kg-action-field <kg-url> |B1| false |control|))

   (<a7> ^device B2
         ^activate true
         ^available (kg-action-field <kg-url> |B2| true |available|)
         ^name (kg-action-field <kg-url> |B2| true |name|)
         ^method (kg-action-field <kg-url> |B2| true |method|)
         ^url (kg-action-field <kg-url> |B2| true |url|)
         ^body (kg-action-field <kg-url> |B2| true |body|)
         ^pre-attribute (kg-action-field <kg-url> |B2| true |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |B2| true |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |B2| true |post-attribute|)
         ^post-value (kg-action-field <kg-url> |B2| true |post-value|)
         ^zone (kg-action-field <kg-url> |B2| true |zone|)
         ^effect (kg-action-field <kg-url> |B2| true |effect|)
         ^control (kg-action-field <kg-url> |B2| true |control|))

   (<a8> ^device B2
         ^activate false
         ^available (kg-action-field <kg-url> |B2| false |available|)
         ^name (kg-action-field <kg-url> |B2| false |name|)
         ^method (kg-action-field <kg-url> |B2| false |method|)
         ^url (kg-action-field <kg-url> |B2| false |url|)
         ^body (kg-action-field <kg-url> |B2| false |body|)
         ^pre-attribute (kg-action-field <kg-url> |B2| false |pre-attribute|)
         ^pre-value (kg-action-field <kg-url> |B2| false |pre-value|)
         ^post-attribute (kg-action-field <kg-url> |B2| false |post-attribute|)
         ^post-value (kg-action-field <kg-url> |B2| false |post-value|)
         ^zone (kg-action-field <kg-url> |B2| false |zone|)
         ^effect (kg-action-field <kg-url> |B2| false |effect|)
         ^control (kg-action-field <kg-url> |B2| false |control|))

   (<c0> ^config-id c0 ^rank 0 ^l1 false ^l2 false ^b1 false ^b2 false)
   (<c1> ^config-id c1 ^rank 1 ^l1 false ^l2 true  ^b1 false ^b2 false)
   (<c2> ^config-id c2 ^rank 2 ^l1 false ^l2 true  ^b1 false ^b2 true)
   (<c3> ^config-id c3 ^rank 3 ^l1 true  ^l2 true  ^b1 false ^b2 true)
   (<c4> ^config-id c4 ^rank 4 ^l1 false ^l2 false ^b1 true  ^b2 true)
   (<c5> ^config-id c5 ^rank 5 ^l1 true  ^l2 false ^b1 true  ^b2 true)
   (<c6> ^config-id c6 ^rank 6 ^l1 true  ^l2 true  ^b1 true  ^b2 true)
   (<c7> ^config-id c7 ^rank 7 ^l1 true  ^l2 false ^b1 false ^b2 false)
   (<c8> ^config-id c8 ^rank 8 ^l1 false ^l2 false ^b1 true  ^b2 false)
   (<c9> ^config-id c9 ^rank 9 ^l1 false ^l2 true  ^b1 true  ^b2 false)
   (<c10> ^config-id c10 ^rank 10 ^l1 true  ^l2 true  ^b1 true  ^b2 false)
   (<c11> ^config-id c11 ^rank 11 ^l1 true  ^l2 false ^b1 true  ^b2 false)
   (<c12> ^config-id c12 ^rank 12 ^l1 false ^l2 false ^b1 false ^b2 true)
   (<c13> ^config-id c13 ^rank 13 ^l1 true  ^l2 false ^b1 false ^b2 true)
   (<c14> ^config-id c14 ^rank 14 ^l1 false ^l2 true  ^b1 true  ^b2 true)
   (<c15> ^config-id c15 ^rank 15 ^l1 true  ^l2 true  ^b1 false ^b2 false)

   (<s> ^action <a1>
        ^action <a2>
        ^action <a3>
        ^action <a4>
        ^action <a5>
        ^action <a6>
        ^action <a7>
        ^action <a8>
        ^config <c0>
        ^config <c1>
        ^config <c2>
        ^config <c3>
        ^config <c4>
        ^config <c5>
        ^config <c6>
        ^config <c7>
        ^config <c8>
        ^config <c9>
        ^config <c10>
        ^config <c11>
        ^config <c12>
        ^config <c13>
        ^config <c14>
        ^config <c15>
        ^action-model-loaded true
        ^config-search-loaded true
        ^needs-refresh true)

   (<s> ^iteration <iteration> -)
   (<s> ^iteration (+ <iteration> 1))
}

sp {light-processing*clear-settle-retries-on-action
   (state <s> ^superstate nil
              ^operator <o>
              ^settle-retries-left <retries>)
   (<o> ^name perform-kg-action)
-->
   (<s> ^settle-retries-left <retries> -)
}

sp {light-processing*clear-no-progress-retries-on-action
   (state <s> ^superstate nil
              ^operator <o>
              ^no-progress-retries-left <retries>)
   (<o> ^name perform-kg-action)
-->
   (<s> ^no-progress-retries-left <retries> -)
}

