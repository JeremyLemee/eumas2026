###############################################################################
# Config-search reset after all combinations have been tried.
###############################################################################

sp {light-processing*propose*reset-config-search-all-configs-tried
   (state <s> ^superstate nil
              ^started true
              ^active-goal <ag>
              ^config-search-loaded true
              ^next-config-rank { <rank> > 15 }
              ^percepts-ready true
              ^iteration { <iteration> < <max> }
              ^max-iterations <max>
              -^current-config <cfg>
              -^pending-device <pd>
              -^needs-refresh true)
-->
   (print-action |[light-processing] PROPOSE reset-config-search: all configurations tried; continuing until max iterations|)
   (<o> ^name reset-config-search
        ^rank <rank>)
   (<s> ^operator <o> +)
}

sp {light-processing*prefer*reset-config-search-over-quiescence
   (state <s> ^superstate nil
              ^operator <reset> +
              ^operator <wait> +)
   (<reset> ^name reset-config-search)
   (<wait> ^name wait-for-quiescence)
-->
   (print-action |[light-processing] PREFERENCE: reset-config-search over wait-for-quiescence|)
   (<s> ^operator <reset> > <wait>)
}

sp {light-processing*apply*reset-config-search
   (state <s> ^superstate nil
              ^operator <o>
              ^next-config-rank <rank>)
   (<o> ^name reset-config-search)
-->
   (print-action |[light-processing] APPLY reset-config-search: clearing tried config marks and restarting config ranks|)
   (<s> ^next-config-rank <rank> -
        ^next-config-rank 0
        ^needs-refresh true)
}

sp {light-processing*cleanup-tried-config-during-reset
   (state <s> ^superstate nil
              ^operator <o>
              ^config <cfg>)
   (<o> ^name reset-config-search)
   (<cfg> ^tried true)
-->
   (<cfg> ^tried true -)
}

