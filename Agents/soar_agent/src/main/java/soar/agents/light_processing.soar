sp {light-processing*prefer*fail-goal-over-wait-for-feedback
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name wait-for-feedback)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over wait-for-feedback|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-clear-pending-disabled
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name clear-pending-disabled)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over clear-pending-disabled|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-select-config
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name select-config)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over select-config|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-config-complete
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name config-complete)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over config-complete|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-abandon-blocked-config
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name abandon-blocked-config)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over abandon-blocked-config|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*prefer*fail-goal-over-reset-config-search
   (state <s> ^superstate nil
              ^operator <fail> +
              ^operator <other> +)
   (<fail> ^name fail-goal)
   (<other> ^name reset-config-search)
-->
   (print-action |[light-processing] PREFERENCE: fail-goal over reset-config-search|)
   (<s> ^operator <fail> > <other>)
}

sp {light-processing*apply*fail-goal
   (state <s> ^superstate nil
              ^operator <o>
              ^active-goal <ag>
              ^goal-event <event-id>
              ^goal-z1 <goal-z1>
              ^goal-z2 <goal-z2>
              ^goal-url <goal-url>
              ^td-url <td-url>
              ^io.output-link <ol>)
   (<o> ^name fail-goal
        ^reason <reason>)
-->
   (print-action |[light-processing] APPLY fail-goal: reason=| <reason> |; sending direct done=false annotation to | <goal-url>)

   (<cmd-done> ^done false
               ^reason <reason>
               ^event-id <event-id>
               ^goal-z1 <goal-z1>
               ^goal-z2 <goal-z2>
               ^url <goal-url>
               ^td-url <td-url>)
   (<ol> ^send-message <cmd-done>)

   (<s> ^active-goal <ag> -
        ^goal-event <event-id> -
        ^goal-z1 <goal-z1> -
        ^goal-z2 <goal-z2> -
        ^goal-url <goal-url> -)

   (print-action |[light-processing] APPLY fail-goal: failed event=| <event-id> | reason=| <reason> |; waiting for next goal|)
}

sp {light-processing*cleanup-percepts-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts <p>)
   (<o> ^name fail-goal)
-->
   (<s> ^percepts <p> -)
}

sp {light-processing*cleanup-percepts-ready-during-fail
   (state <s> ^superstate nil
              ^operator <o>
              ^percepts-ready true)
   (<o> ^name fail-goal)
-->
   (<s> ^percepts-ready true -)
}

