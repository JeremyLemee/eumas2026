###############################################################################
# Output-link cleanup
#
# The Java output handler should add:
#   ^status complete
# to command objects after executing them.
###############################################################################

sp {light-processing*cleanup*completed-http-request
   (state <s> ^superstate nil
              ^io.output-link <ol>)
   (<ol> ^send-http-request <req>)
   (<req> ^status complete)
-->
   (print-action |[light-processing] CLEANUP completed HTTP request|)
   (<ol> ^send-http-request <req> -)
}

sp {light-processing*cleanup*completed-register-profile
   (state <s> ^superstate nil
              ^io.output-link <ol>)
   (<ol> ^register-profile <cmd>)
   (<cmd> ^status complete)
-->
   (print-action |[light-processing] CLEANUP completed register-profile command|)
   (<ol> ^register-profile <cmd> -)
}

sp {light-processing*cleanup*completed-send-message
   (state <s> ^superstate nil
              ^io.output-link <ol>)
   (<ol> ^send-message <cmd>)
   (<cmd> ^status complete)
-->
   (print-action |[light-processing] CLEANUP completed send-message command|)
   (<ol> ^send-message <cmd> -)
}
