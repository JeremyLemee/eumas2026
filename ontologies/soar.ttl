@prefix : <http://example.org/soar#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/soar#> .

<http://example.org/soar#> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/soar#hasAttribute
:hasAttribute rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Wme ;
              rdfs:range :Symbol .


###  http://example.org/soar#hasIdentifier
:hasIdentifier rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain :Wme ;
               rdfs:range :Identifier ;
               rdfs:comment "The identifier of a WME." .


###  http://example.org/soar#hasInputLink
:hasInputLink rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :SoarInput ;
              rdfs:range :Identifier .


###  http://example.org/soar#hasLiteral
:hasLiteral rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain :Symbol .


###  http://example.org/soar#hasRelation
:hasRelation rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Wme ;
             rdfs:range :Symbol ;
             rdfs:comment "The relation of a WME." .


###  http://example.org/soar#hasValue
:hasValue rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :Wme ;
          rdfs:range :Symbol ;
          rdfs:comment "The value of a Wme." .


#################################################################
#    Data properties
#################################################################

###  http://example.org/soar#done
:done rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdfs:range xsd:boolean ;
      rdfs:comment "A boolean indicating whether the goal has been achieved." .


###  http://example.org/soar#hasLiteral
:hasLiteral rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty .


###  http://example.org/soar#reason
:reason rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:range rdfs:Literal ;
        rdfs:comment "The reason for a decision." .


#################################################################
#    Classes
#################################################################

###  http://example.org/soar#AddWme
:AddWme rdf:type owl:Class ;
        rdfs:comment "An action to add WMEs to Soar's working memory." .


###  http://example.org/soar#Identifier
:Identifier rdf:type owl:Class ;
            rdfs:subClassOf :Symbol .


###  http://example.org/soar#SoarInput
:SoarInput rdf:type owl:Class ;
           rdfs:comment "A representation of the Soar agent's input link." .


###  http://example.org/soar#Symbol
:Symbol rdf:type owl:Class ;
        rdfs:comment "A Soar symbol." .


###  http://example.org/soar#Wme
:Wme rdf:type owl:Class ;
     rdfs:comment "A working memory element in Soar." .


###  http://example.org/soar#soar_ability
:soar_ability rdf:type owl:Class ;
              rdfs:subClassOf <https://purl.org/hmas/Ability> .


###  http://example.org/soar#soar_light_processing
:soar_light_processing rdf:type owl:Class ;
                       rdfs:subClassOf <https://purl.org/hmas/Ability> .


###  https://purl.org/hmas/Ability
<https://purl.org/hmas/Ability> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://example.org/soar#InputId
:InputId rdf:type owl:NamedIndividual ,
                  :Identifier .


#################################################################
#    Annotations
#################################################################

:hasLiteral rdfs:comment "Information about a literal." .


