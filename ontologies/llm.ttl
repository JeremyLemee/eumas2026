###  http://example.org/llm#text_action
:text_action rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "A text representing an action to perform." .


#################################################################
#    Classes
#################################################################

###  http://example.org/llm#llm_ability
:llm_ability rdf:type owl:Class ;
             rdfs:subClassOf <https://purl.org/hmas/Ability> ;
             rdfs:comment "An ability that the agent is able to use an LLM." .


###  http://example.org/llm#llm_action
:llm_action rdf:type owl:Class ;
            rdfs:comment "An action expressed in natural language." .


###  https://purl.org/hmas/Ability
<https://purl.org/hmas/Ability> rdf:type owl:Class .


