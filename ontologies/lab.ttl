@base <http://example.org/lab#> .

<http://example.org/lab#> rdf:type owl:Ontology .

#################################################################
#    Data properties
#################################################################

###  http://example.org/lab#B1Status
:B1Status rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:comment "A boolean indicating whether the blinds in zone 1 are enabled or disabled." .


###  http://example.org/lab#B2Status
:B2Status rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:comment "A boolean indicating whether the blinds in zone 2 are enabled or disabled." .


###  http://example.org/lab#L1Status
:L1Status rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:comment "A boolean indicating whether the lights in zone 1 are enabled or disabled." .


###  http://example.org/lab#L2Status
:L2Status rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:comment "A boolean indicating whether the lights in zone 2 are enabled or disabled." .


###  http://example.org/lab#hasSunshine
:hasSunshine rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:comment "The sunshine level." .


###  http://example.org/lab#hasTimestamp
:hasTimestamp rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:comment "A timestamp for an annotation." .


###  http://example.org/lab#hasZ1Blinds
:hasZ1Blinds rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty .


###  http://example.org/lab#hasZ1Level
:hasZ1Level rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty .


###  http://example.org/lab#hasZ1Light
:hasZ1Light rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty .


###  http://example.org/lab#hasZ2Blinds
:hasZ2Blinds rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty .


###  http://example.org/lab#hasZ2Level
:hasZ2Level rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty .


###  http://example.org/lab#hasZ2Light
:hasZ2Light rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty .


