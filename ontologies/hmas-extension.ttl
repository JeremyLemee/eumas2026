#    Classes
#################################################################

###  https://purl.org/hmas/Content
:Content rdf:type owl:Class .


###  https://purl.org/hmas/Situation
:Situation rdf:type owl:Class .


###  https://purl.org/hmas//Ability
:Ability rdf:type owl:Class .


###  https://purl.org/hmas//Agent
:Agent rdf:type owl:Class .


###  https://purl.org/hmas//Annotation
:Annotation rdf:type owl:Class ;
            rdfs:subClassOf :Information .


###  https://purl.org/hmas//Artifact
:Artifact rdf:type owl:Class .


###  https://purl.org/hmas//BehaviorExecution
:BehaviorExecution rdf:type owl:Class .


###  https://purl.org/hmas//Condition
:Condition rdf:type owl:Class .


###  https://purl.org/hmas//Goal
:Goal rdf:type owl:Class .


###  https://purl.org/hmas//Information
:Information rdf:type owl:Class .


###  https://purl.org/hmas//InteractionPolicy
:InteractionPolicy rdf:type owl:Class .


###  https://purl.org/hmas//Message
:Message rdf:type owl:Class ;
         rdfs:subClassOf :Information .


###  https://purl.org/hmas//MessagePolicy
:MessagePolicy rdf:type owl:Class ;
               rdfs:subClassOf :InteractionPolicy .


###  https://purl.org/hmas//Operation
:Operation rdf:type owl:Class .


###  https://purl.org/hmas//Procedure
:Procedure rdf:type owl:Class .


###  https://purl.org/hmas//RecurrentPolicy
:RecurrentPolicy rdf:type owl:Class ;
                 rdfs:subClassOf :InteractionPolicy .


###  https://purl.org/hmas//Signifier
:Signifier rdf:type owl:Class ;
           rdfs:subClassOf :Annotation ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :signifies ;
                             owl:minCardinality "1"^^xsd:nonNegativeInteger
                           ] .


###  https://purl.org/hmas//State
:State rdf:type owl:Class .


