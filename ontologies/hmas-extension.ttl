@prefix : <https://purl.org/hmas//> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://purl.org/hmas//> .

<https://purl.org/hmas/> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  https://purl.org/hmas//conveys
:conveys rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Information ;
         rdfs:comment "Provides the content conveyed by information." .


###  https://purl.org/hmas//hasCallbackUrl
:hasCallbackUrl rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain :RecurrentPolicy ;
                rdfs:comment "Indicates the callback URL to send annotations to an agent." .


###  https://purl.org/hmas//hasCreatorId
:hasCreatorId rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Annotation ;
              rdfs:range :Agent ;
              rdfs:comment "A link to the agent creating an annotation." .


###  https://purl.org/hmas//hasGoal
:hasGoal rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Agent ;
         rdfs:range :Goal ;
         rdfs:comment "A link to the agent's goal." .


###  https://purl.org/hmas//hasInteractionPolicy
:hasInteractionPolicy rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty ;
                      rdfs:domain :Agent ;
                      rdfs:range :InteractionPolicy ;
                      rdfs:comment "A link to an interaction policy that an agent has." .


###  https://purl.org/hmas//hasMessageUrl
:hasMessageUrl rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain :MessagePolicy ;
               rdfs:comment "A link to an URL to send messages to an agent." .


###  https://purl.org/hmas//hasOperation
:hasOperation rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Procedure ;
              rdfs:range :Operation ;
              rdfs:comment "A link to the operation described by a procedure." .


###  https://purl.org/hmas//hasPostcondition
:hasPostcondition rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty ;
                  rdfs:domain :Procedure ;
                  rdfs:comment "A link to the postcondition of a procedure (e.g., the result of performing the operation described by the procedure)." .


###  https://purl.org/hmas//hasPrecondition
:hasPrecondition rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Procedure ;
                 rdfs:comment "A link to the precondition of a procedure (e.g., the condition required to perform the operation described by the procedure)." .


###  https://purl.org/hmas//hasProcedure
:hasProcedure rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Artifact ;
              rdfs:range :Procedure ;
              rdfs:comment "A link to a procedure that an artifact enables." .


###  https://purl.org/hmas//hasReceiver
:hasReceiver rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Message ;
             rdfs:range :Agent ;
             rdfs:comment "A link to an agent meant to receive a message" .


###  https://purl.org/hmas//hasSender
:hasSender rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Message ;
           rdfs:range :Agent ;
           rdfs:comment "A link to the agent sending a message." .


###  https://purl.org/hmas//hasSituation
:hasSituation rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Agent ;
              rdfs:comment "The situation of an agent." .


###  https://purl.org/hmas//hasState
:hasState rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :Artifact ;
          rdfs:range :State ;
          rdfs:comment "A link to the state of an artifact." .


###  https://purl.org/hmas//recommendsAbility
:recommendsAbility rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdfs:domain :Information ;
                   rdfs:range :Ability .


###  https://purl.org/hmas//recommendsContext
:recommendsContext rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdfs:domain :Annotation .


###  https://purl.org/hmas//signifies
:signifies rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :conveys ;
           rdfs:domain :Signifier ;
           rdfs:range :BehaviorExecution .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2002/07/owl#topDataProperty
owl:topDataProperty rdfs:domain :Information ;
                    rdfs:range xsd:string .


###  https://purl.org/hmas//hasId
:hasId rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf owl:topDataProperty ;
       rdfs:domain :Information ;
       rdfs:comment "A link to an identifier for some information." .


#################################################################
#    Classes
#################################################################

###  https://purl.org/hmas//Ability
:Ability rdf:type owl:Class ;
         rdfs:comment "An ability possessed by an agent." .


###  https://purl.org/hmas//Agent
:Agent rdf:type owl:Class .


###  https://purl.org/hmas//Annotation
:Annotation rdf:type owl:Class ;
            rdfs:subClassOf :Information .


###  https://purl.org/hmas//Artifact
:Artifact rdf:type owl:Class .


###  https://purl.org/hmas//BehaviorExecution
:BehaviorExecution rdf:type owl:Class .


###  https://purl.org/hmas//Goal
:Goal rdf:type owl:Class ;
      rdfs:comment "A goal of an agent." .


###  https://purl.org/hmas//Information
:Information rdf:type owl:Class ;
             rdfs:comment "A general class for information conveyed to agents" .


###  https://purl.org/hmas//InteractionPolicy
:InteractionPolicy rdf:type owl:Class ;
                   rdfs:comment "A policy indicating how the agent can be interacted with and for what purpose." .


###  https://purl.org/hmas//Message
:Message rdf:type owl:Class ;
         rdfs:subClassOf :Information .


###  https://purl.org/hmas//MessagePolicy
:MessagePolicy rdf:type owl:Class ;
               rdfs:subClassOf :InteractionPolicy .


###  https://purl.org/hmas//Operation
:Operation rdf:type owl:Class ;
           rdfs:comment "An operation that can be performed in the environment." .


###  https://purl.org/hmas//Procedure
:Procedure rdf:type owl:Class ;
           rdfs:comment "An operation that can be performed in the environment, associated with preconditions and postconditions." .


###  https://purl.org/hmas//RecurrentPolicy
:RecurrentPolicy rdf:type owl:Class ;
                 rdfs:subClassOf :InteractionPolicy .


###  https://purl.org/hmas//Signifier
:Signifier rdf:type owl:Class ;
           rdfs:subClassOf :Annotation ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :signifies ;
                             owl:minCardinality "1"^^xsd:nonNegativeInteger
                           ] .


###  https://purl.org/hmas//State
:State rdf:type owl:Class ;
       rdfs:comment "The state of an artifact" .


