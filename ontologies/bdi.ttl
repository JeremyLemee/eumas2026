@prefix : <http://example.org/bdi#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/bdi#> .

<http://localhost:8082/ontologies/bdi#> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/bdi#hasStatement
:hasStatement rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:range :Literal ;
              rdfs:comment "A link to a statement, represented has a literal." .


###  http://example.org/bdi#hasValues
:hasValues rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Literal ;
           rdfs:comment "The values of the predicate statement as an RDF List." .


#################################################################
#    Data properties
#################################################################

###  http://example.org/bdi#hasPredicate
:hasPredicate rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :Literal ;
              rdfs:range xsd:string ;
              rdfs:comment "The name of the predicate of a predicate statement" .


#################################################################
#    Classes
#################################################################

###  http://example.org/bdi#AddBelief
:AddBelief rdf:type owl:Class .


###  http://example.org/bdi#Literal
:Literal rdf:type owl:Class ;
         rdfs:comment "A predicate statement, that can be used to represent the belief of a BDI agent." .


###  http://example.org/bdi#disable_z1_blinds
:disable_z1_blinds rdf:type owl:Class ;
                   rdfs:subClassOf <https://purl.org/hmas/Goal> ;
                   rdfs:comment "The goal to disable the blinds in zone 1." .


###  http://example.org/bdi#disable_z2_blinds
:disable_z2_blinds rdf:type owl:Class ;
                   rdfs:subClassOf <https://purl.org/hmas/Goal> ;
                   rdfs:comment "The goal to disable the blinds in zone 2." .


###  http://example.org/bdi#predicate_ability
:predicate_ability rdf:type owl:Class ;
                   rdfs:subClassOf <https://purl.org/hmas/Ability> ;
                   rdfs:comment "The ability to process first order logic statements." .


###  http://example.org/bdi#set_env
:set_env rdf:type owl:Class ;
         rdfs:subClassOf <https://purl.org/hmas/Ability> ;
         rdfs:comment "Ability to process incoming set_env beliefs. Z1 refers to the desired light level in zone 1. Z2 refers to the desired light level in zone 2. Url refers to a callback URL. The beliefs that the agent can process are set_env(Z1, Z2, Url) to set the light levels of zone 1 and zone 2 and then send back a response to an agent indicating with the URL. The agent can also process the following variations: set_env(Z1, Z2, Url, human(H1)) and set_env(Z1, Z2, Url, human(Z1,Z2)). These variations indicate the presence of a human in zone 1, in zone 2, or both where H1 and H2 correspond to zones where humans are present." .


###  https://purl.org/hmas/Ability
<https://purl.org/hmas/Ability> rdf:type owl:Class .


###  https://purl.org/hmas/Goal
<https://purl.org/hmas/Goal> rdf:type owl:Class .


